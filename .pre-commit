#!/usr/bin/env bash
#
# Pre-commit Hook - Prevent Direct Pushes to Main Branch
# This hook prevents direct commits to the main branch and enforces
# proper development workflow through feature branches.
#

set -euo pipefail

# Colors for output (respecting NO_COLOR environment variable)
if [[ -z "${NO_COLOR:-}" ]] && [[ "${GITHUB_ACTIONS:-false}" != "true" ]]; then
    readonly RED='\033[31m'
    readonly YELLOW='\033[33m'
    readonly BLUE='\033[36m'
    readonly GREEN='\033[32m'
    readonly RESET='\033[0m'
else
    readonly RED=''
    readonly YELLOW=''
    readonly BLUE=''
    readonly GREEN=''
    readonly RESET=''
fi

# Output functions
show_error() {
    printf "%b✗ Error:%b %s\n" "$RED" "$RESET" "$*" >&2
}

show_warning() {
    printf "%b⚠ Warning:%b %s\n" "$YELLOW" "$RESET" "$*" >&2
}

show_info() {
    printf "%bℹ Info:%b %s\n" "$BLUE" "$RESET" "$*"
}

show_success() {
    printf "%b✓ Success:%b %s\n" "$GREEN" "$RESET" "$*"
}

# Get current branch name
get_current_branch() {
    git rev-parse --abbrev-ref HEAD 2>/dev/null || echo ""
}

# Check if we're in a Git repository
is_git_repository() {
    git rev-parse --git-dir >/dev/null 2>&1
}

# Check if the current branch is main or master
is_main_branch() {
    local current_branch="$1"
    [[ "$current_branch" == "main" ]] || [[ "$current_branch" == "master" ]]
}

# Check if there are any staged changes
has_staged_changes() {
    ! git diff --cached --quiet
}

# Main validation logic
validate_commit() {
    # Verify we're in a git repository
    if ! is_git_repository; then
        show_error "Not in a Git repository"
        return 1
    fi

    # Get current branch
    local current_branch
    current_branch=$(get_current_branch)
    
    if [[ -z "$current_branch" ]]; then
        show_error "Unable to determine current branch"
        return 1
    fi

    show_info "Current branch: $current_branch"

    # Check if we're trying to commit directly to main/master
    if is_main_branch "$current_branch"; then
        show_error "Direct commits to the '$current_branch' branch are not allowed"
        echo
        show_warning "To maintain code quality and enable proper review processes,"
        show_warning "all changes must go through feature branches."
        echo
        show_info "Recommended workflow:"
        show_info "1. Create a feature branch:"
        show_info "   git checkout -b feature/your-feature-name"
        echo
        show_info "2. Make your changes and commit:"
        show_info "   git add ."
        show_info "   git commit -m \"your commit message\""
        echo
        show_info "3. Push the feature branch:"
        show_info "   git push origin feature/your-feature-name"
        echo
        show_info "4. Create a pull request for review"
        echo
        show_warning "If you need to make an emergency fix to main, you can:"
        show_warning "1. Temporarily disable this hook: mv .pre-commit .pre-commit.disabled"
        show_warning "2. Make your emergency commit"
        show_warning "3. Re-enable the hook: mv .pre-commit.disabled .pre-commit"
        echo
        return 1
    fi

    # Verify there are staged changes
    if ! has_staged_changes; then
        show_warning "No staged changes found"
        show_info "Use 'git add <files>' to stage changes before committing"
        return 1
    fi

    show_success "Pre-commit validation passed"
    show_info "Proceeding with commit on branch '$current_branch'"
    return 0
}

# Help function
show_help() {
    cat << 'EOF'
Pre-commit Hook - Prevent Direct Pushes to Main Branch

DESCRIPTION:
    This pre-commit hook prevents direct commits to the main/master branch
    to enforce proper development workflow through feature branches.

BEHAVIOR:
    - Blocks commits to 'main' or 'master' branches
    - Provides helpful workflow guidance
    - Allows commits on all other branches
    - Can be temporarily disabled for emergency fixes

USAGE:
    This hook runs automatically on 'git commit'. To install:
    
    # Make executable (if not already)
    chmod +x .pre-commit
    
    # Install as Git hook
    ln -sf ../../.pre-commit .git/hooks/pre-commit

EMERGENCY BYPASS:
    If you need to make an emergency commit to main:
    
    # Temporarily disable
    mv .pre-commit .pre-commit.disabled
    
    # Make emergency commit
    git commit -m "emergency: fix critical issue"
    
    # Re-enable hook
    mv .pre-commit.disabled .pre-commit

ENVIRONMENT VARIABLES:
    NO_COLOR=1     Disable colored output
    
EXIT CODES:
    0    Success - commit allowed
    1    Error - commit blocked

EOF
}

# Main execution
main() {
    # Check for help request
    if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
        show_help
        exit 0
    fi

    # Run validation
    if validate_commit; then
        exit 0
    else
        exit 1
    fi
}

# Execute main function
main "$@"
